# Copy to .env.local and fill in.

# OpenAI — for real AI generation. Without it, dev falls back to mock data.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Supabase — for community features (login + đăng bài). Optional: if unset, the
# app runs fine and the community UI (Đăng nhập / Đăng bài) is hidden.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin — used for Open Graph / link-preview absolute URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
